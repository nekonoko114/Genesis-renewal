    <!-- Scripts -->
    <script is:inline>
      // Smooth Parallax Effect
      const blobs = [
        { el: document.getElementById('blob-1'), speed: 0.12 },
        { el: document.getElementById('blob-2'), speed: -0.08 },
        { el: document.getElementById('blob-3'), speed: 0.05 }
      ];

      let ticking = false;

      function updateParallax() {
        const scrolled = window.pageYOffset;

        blobs.forEach(blob => {
          if (blob.el) {
            blob.el.style.transform = `translate3d(0, ${scrolled * blob.speed}px, 0)`;
          }
        });

        ticking = false;
      }

      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(updateParallax);
          ticking = true;
        }
      });
      updateParallax();

      // Subtle header border on scroll
      window.addEventListener('scroll', () => {
          const header = document.getElementById('header');
          if (window.scrollY > 20) {
              header.classList.add('border-gray-200', 'shadow-sm', 'bg-creamy-bg/95');
              header.classList.remove('border-transparent', 'bg-creamy-bg/80');
          } else {
              header.classList.remove('border-gray-200', 'shadow-sm', 'bg-creamy-bg/95');
              header.classList.add('border-transparent', 'bg-creamy-bg/80');
          }
      });

      // Mobile Menu Toggle
      const btn = document.getElementById('menu-btn');
      const closeBtn = document.getElementById('close-btn');
      const menu = document.getElementById('mobile-menu');
      const links = document.querySelectorAll('.mobile-link');
      
      const openMenu = () => {
        menu.classList.remove('hidden');
        menu.classList.add('flex');
        // Small delay for transition
        setTimeout(() => {
          menu.classList.remove('opacity-0');
          menu.classList.add('opacity-100');
        }, 10);
        document.body.style.overflow = 'hidden';
      };
      
      const closeMenu = () => {
        menu.classList.remove('opacity-100');
        menu.classList.add('opacity-0');
        setTimeout(() => {
          menu.classList.add('hidden');
          menu.classList.remove('flex');
          document.body.style.overflow = '';
        }, 300);
      };
      
      btn.addEventListener('click', openMenu);
      closeBtn.addEventListener('click', closeMenu);
      links.forEach(link => link.addEventListener('click', closeMenu));
    </script>
  </body>
</html>
