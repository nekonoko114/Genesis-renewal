---
import '../../styles/tailwind.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="ja" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>トータルソリューション事業部 | Genesis合同会社</title>
    <meta name="description" content="不確実な時代だからこそ、確かな専門知識と実績を持つパートナーが必要です。総合人材ソリューション、有料職業紹介・労働者派遣、補助金サポート、代理店業務を通じて貴社のビジネス成長を支援します。">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700;900&display=swap" rel="stylesheet">

    <style>
      .text-gradient-c {
        background: linear-gradient(to right, #FF9494, #C994FF, #94FFFF);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .elegant-shadow {
        box-shadow: 0 20px 40px -10px rgba(0,0,0,0.05);
      }
      ::-webkit-scrollbar { width: 4px; }
      ::-webkit-scrollbar-track { background: #fcfcfc; }
      ::-webkit-scrollbar-thumb { background: #e5e7eb; border-radius: 2px; }
      ::-webkit-scrollbar-thumb:hover { background: #C994FF; }

      /* Enhanced Tech Grid with subtle dots */
      .tech-grid {
        background-image:
          radial-gradient(rgba(201, 148, 255, 0.08) 1.5px, transparent 1.5px),
          linear-gradient(to right, rgba(0, 0, 0, 0.02) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(0, 0, 0, 0.02) 1px, transparent 1px);
        background-size: 40px 40px, 80px 80px, 80px 80px;
      }

      /* Floating Blob Animation */
      @keyframes float-slow {
        0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
        33% { transform: translate(50px, -80px) scale(1.15) rotate(120deg); }
        66% { transform: translate(-30px, 30px) scale(0.85) rotate(240deg); }
      }
      @keyframes float-reverse {
        0%, 100% { transform: translate(0, 0) scale(1.1) rotate(0deg); }
        33% { transform: translate(-40px, 60px) scale(0.9) rotate(-120deg); }
        66% { transform: translate(30px, -40px) scale(1.05) rotate(-240deg); }
      }
      .animate-float-1 {
        animation: float-slow 35s infinite alternate ease-in-out;
      }
      .animate-float-2 {
        animation: float-reverse 40s infinite alternate ease-in-out;
      }

      /* Glassmorphism Card */
      .glass-card {
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255, 255, 255, 0.55);
        box-shadow: 0 30px 60px -15px rgba(0,0,0,0.03), inset 0 1px 0 rgba(255,255,255,0.6);
      }

      .parallax-bg {
        will-change: transform;
      }
    </style>
  </head>
  <body class="bg-creamy-bg text-gray-800 font-outfit overflow-x-hidden selection:bg-triad-purple selection:text-white relative tech-grid">
    <!-- Super subtle background accents & parallax blobs -->
    <div class="fixed top-0 left-0 w-full h-full pointer-events-none z-[-1] overflow-hidden">
        <div id="blob-1" class="parallax-bg absolute -top-48 -left-48 w-[700px] h-[700px] bg-triad-cyan rounded-full mix-blend-multiply opacity-25 filter blur-[120px] animate-float-1"></div>
        <div id="blob-2" class="parallax-bg absolute top-1/3 -right-48 w-[650px] h-[650px] bg-triad-purple rounded-full mix-blend-multiply opacity-20 filter blur-[120px] animate-float-2"></div>
        <div id="blob-3" class="parallax-bg absolute -bottom-48 left-1/4 w-[800px] h-[800px] bg-triad-pink rounded-full mix-blend-multiply opacity-20 filter blur-[150px] animate-float-1"></div>
    </div>

    <Header />

    <!-- MAIN CONTENT -->
    <main class="pt-32">
      <!-- Header Area -->
      <section class="max-w-7xl mx-auto px-6 lg:px-12 py-16 text-center">
        <span class="text-triad-cyan font-bold tracking-[0.3em] text-xs uppercase mb-4 block">Total Solution Division</span>
        <h1 class="text-5xl md:text-7xl font-black text-gray-900 tracking-tight leading-none mb-6">
          トータルソリューション
        </h1>
        <p class="text-lg md:text-xl text-gray-500 font-light max-w-2xl mx-auto leading-relaxed mb-12">
          単なるソリューション提供で終わらせません。「企業価値の最大化」という共通目標の実現まで、責任を持って伴走いたします。
        </p>

        <!-- Huge Panoramic Visual Image -->
        <div class="relative w-full aspect-[16/10] md:aspect-[21/9] rounded-[40px] overflow-hidden elegant-shadow group">
          <!-- Ambient Glow behind the image -->
          <div class="absolute -inset-4 bg-gradient-to-r from-triad-cyan via-triad-purple to-triad-lime rounded-[40px] opacity-20 filter blur-3xl group-hover:opacity-35 transition-opacity duration-700 pointer-events-none"></div>
          
          <img src="/assets/images/pages/corporate_sales.png" alt="トータルソリューション" class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-1000 ease-out z-10 relative" loading="lazy" decoding="async" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-black/20 z-20"></div>
          
          <!-- Badge on the image -->
          <div class="absolute bottom-8 left-8 md:bottom-12 md:left-12 z-30 text-left">
            <span class="bg-triad-cyan text-gray-900 text-xs font-bold uppercase tracking-widest px-5 py-2.5 rounded-full backdrop-blur-sm shadow-sm">
              Business Transformation
            </span>
          </div>
        </div>
      </section>

      <!-- Main Description -->
      <section class="max-w-5xl mx-auto px-6 lg:px-12 py-8">
        <div class="glass-card rounded-[40px] p-8 md:p-16 text-center relative overflow-hidden">
          <div class="absolute -top-24 -left-24 w-48 h-48 bg-triad-cyan rounded-full mix-blend-multiply opacity-5 filter blur-3xl"></div>
          <h2 class="text-2xl md:text-3xl font-black text-gray-900 mb-6">SERVICE</h2>
          <p class="text-gray-500 font-light leading-relaxed max-w-3xl mx-auto">
            企業の根かった「人」の課題や「IT・DX」の推進に対し、長年にわたり培った深い専門知見を投じ、多角的な支援を提供します。
          </p>
        </div>
      </section>

      <!-- Services List Section -->
      <section class="max-w-7xl mx-auto px-6 lg:px-12 py-20">
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-16 text-center">Service Core Areas</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 max-w-5xl mx-auto">
          <!-- Area 1 -->
          <div class="glass-card rounded-[40px] p-6 md:p-8 group hover:-translate-y-2 transition-all duration-500 flex flex-col justify-between relative overflow-hidden">
            <div class="absolute -top-12 -right-12 w-32 h-32 bg-triad-red rounded-full mix-blend-multiply opacity-5 filter blur-[30px] group-hover:scale-150 transition-transform duration-700"></div>
            <div>
              <div class="overflow-hidden rounded-[24px] mb-6 aspect-[16/10] relative">
                <img src="/assets/images/pages/recruitment_service.png" alt="総合人材ソリューション" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" decoding="async" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent"></div>
              </div>
              <span class="text-triad-red font-bold tracking-[0.2em] text-xs uppercase mb-4 block border-b-2 border-triad-red pb-2 inline-block">Area 01 / Human Resources</span>
              <h3 class="text-xl font-black text-gray-900 mb-4">総合人材ソリューション</h3>
              <p class="text-gray-500 font-light leading-relaxed text-sm">
                企業の根幹を成す「人」の課題に対し、長年にわたり培った深い専門知見を投じ、採用設計から育成・定着支援まで多角的な人材ソリューションを提供します。
              </p>
            </div>
            <div class="w-12 h-1 bg-triad-red mt-6"></div>
          </div>

          <!-- Area 2 -->
          <div class="glass-card rounded-[40px] p-6 md:p-8 group hover:-translate-y-2 transition-all duration-500 flex flex-col justify-between relative overflow-hidden">
            <div class="absolute -top-12 -right-12 w-32 h-32 bg-triad-purple rounded-full mix-blend-multiply opacity-5 filter blur-[30px] group-hover:scale-150 transition-transform duration-700"></div>
            <div>
              <div class="overflow-hidden rounded-[24px] mb-6 aspect-[16/10] relative">
                <img src="/assets/images/pages/about_philosophy.png" alt="有料職業紹介事業" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" decoding="async" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent"></div>
              </div>
              <span class="text-triad-purple font-bold tracking-[0.2em] text-xs uppercase mb-4 block border-b-2 border-triad-purple pb-2 inline-block">Area 02 / Recruitment License</span>
              <h3 class="text-xl font-black text-gray-900 mb-4">有料職業紹介事業</h3>
              <p class="text-gray-500 font-light leading-relaxed text-sm">
                免許の最適かつ有効な活用戦略と、事業の収益最大化に向けたコンサルティングを提供いたします。また、有料職業紹介に留まらず、一般派遣、紹介予定派遣を含む労働者派遣事業にも柔軟に対応します。
              </p>
            </div>
            <div class="w-12 h-1 bg-triad-purple mt-6"></div>
          </div>

          <!-- Area 3 -->
          <div class="glass-card rounded-[40px] p-6 md:p-8 group hover:-translate-y-2 transition-all duration-500 flex flex-col justify-between relative overflow-hidden">
            <div class="absolute -top-12 -right-12 w-32 h-32 bg-triad-cyan rounded-full mix-blend-multiply opacity-5 filter blur-[30px] group-hover:scale-150 transition-transform duration-700"></div>
            <div>
              <div class="overflow-hidden rounded-[24px] mb-6 aspect-[16/10] relative">
                <img src="/assets/images/pages/web_production.png" alt="補助金サポート事業" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" decoding="async" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent"></div>
              </div>
              <span class="text-triad-cyan font-bold tracking-[0.2em] text-xs uppercase mb-4 block border-b-2 border-triad-cyan pb-2 inline-block">Area 03 / Subsidy & DX</span>
              <h3 class="text-xl font-black text-gray-900 mb-4">補助金サポート事業</h3>
              <p class="text-gray-500 font-light leading-relaxed text-sm">
                ITツール導入による生産性向上戦略の立案から、採択実績に裏打ちされた補助金申請手続きの強力なサポートまでを、一貫してご提供し、企業のDX化を伴走推進します。
              </p>
            </div>
            <div class="w-12 h-1 bg-triad-cyan mt-6"></div>
          </div>

          <!-- Area 4 -->
          <div class="glass-card rounded-[40px] p-6 md:p-8 group hover:-translate-y-2 transition-all duration-500 flex flex-col justify-between relative overflow-hidden">
            <div class="absolute -top-12 -right-12 w-32 h-32 bg-triad-lime rounded-full mix-blend-multiply opacity-5 filter blur-[30px] group-hover:scale-150 transition-transform duration-700"></div>
            <div>
              <div class="overflow-hidden rounded-[24px] mb-6 aspect-[16/10] relative">
                <img src="/assets/images/pages/corporate_sales.png" alt="代理店業務" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" decoding="async" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent"></div>
              </div>
              <span class="text-triad-lime font-bold tracking-[0.2em] text-xs uppercase mb-4 block border-b-2 border-triad-lime pb-2 inline-block">Area 04 / Partner Sales</span>
              <h3 class="text-xl font-black text-gray-900 mb-4">代理店業務</h3>
              <p class="text-gray-500 font-light leading-relaxed text-sm">
                企業様との強固なパートナーシップのもと、販売代理店事業を展開しております。Genesisの営業部門が持つ販売ノウハウを最大限に活かし、売上拡大を強力にバックアップいたします。
              </p>
            </div>
            <div class="w-12 h-1 bg-triad-lime mt-6"></div>
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="max-w-7xl mx-auto px-6 lg:px-12 py-16 pb-32">
        <div class="bg-gray-900 rounded-[40px] py-12 px-6 md:p-20 text-center relative overflow-hidden flex flex-col items-center">
          <div class="absolute w-[500px] h-[500px] bg-gradient-to-tr from-triad-cyan to-triad-purple rounded-full filter blur-[100px] opacity-15 top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
          <h2 class="text-2xl sm:text-3xl md:text-5xl font-black text-white mb-6 relative z-10 leading-snug">ビジネスのさらなる成長に向けて</h2>
          <p class="text-gray-400 font-light max-w-xl mx-auto mb-10 relative z-10 text-sm md:text-base">
            貴社の経営課題や採用・DXに関するご相談を幅広く承っております。どうぞお気軽にお問い合わせください。
          </p>
          <a href="/contact/" class="relative z-10 inline-flex items-center justify-center bg-white text-gray-900 font-bold px-10 py-5 rounded-full hover:scale-105 transition-all duration-300">
            お問合わせをする
          </a>
        </div>
      </section>
    </main>

    <Footer />

    <!-- Scripts -->
    <script is:inline>
      // Smooth Parallax Effect
      const blobs = [
        { el: document.getElementById('blob-1'), speed: 0.12 },
        { el: document.getElementById('blob-2'), speed: -0.08 },
        { el: document.getElementById('blob-3'), speed: 0.05 }
      ];

      let ticking = false;

      function updateParallax() {
        const scrolled = window.pageYOffset;

        blobs.forEach(blob => {
          if (blob.el) {
            blob.el.style.transform = `translate3d(0, ${scrolled * blob.speed}px, 0)`;
          }
        });

        ticking = false;
      }

      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(updateParallax);
          ticking = true;
        }
      });
      updateParallax();
    </script>
  </body>
</html>
