---
import '../styles/tailwind.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="ja" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>お問い合わせ | Genesis合同会社</title>
    <meta name="description" content="Genesis合同会社へのお問い合わせページです。WEBサイト制作、WEBマーケティング、システム開発など、お気軽にご相談ください。">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700;900&display=swap" rel="stylesheet">

    <style>
      .text-gradient-c {
        background: linear-gradient(to right, #FF9494, #C994FF, #94FFFF);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .elegant-shadow {
        box-shadow: 0 20px 40px -10px rgba(0,0,0,0.05);
      }
      ::-webkit-scrollbar { width: 4px; }
      ::-webkit-scrollbar-track { background: #fcfcfc; }
      ::-webkit-scrollbar-thumb { background: #e5e7eb; border-radius: 2px; }
      ::-webkit-scrollbar-thumb:hover { background: #C994FF; }

      /* Tech Grid Pattern */
      .tech-grid {
        background-image:
          linear-gradient(to right, rgba(0, 0, 0, 0.02) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(0, 0, 0, 0.02) 1px, transparent 1px);
        background-size: 60px 60px;
      }

      /* Floating Blob Animation */
      @keyframes float-slow {
        0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
        33% { transform: translate(50px, -80px) scale(1.15) rotate(120deg); }
        66% { transform: translate(-30px, 30px) scale(0.85) rotate(240deg); }
      }
      @keyframes float-reverse {
        0%, 100% { transform: translate(0, 0) scale(1.1) rotate(0deg); }
        33% { transform: translate(-40px, 60px) scale(0.9) rotate(-120deg); }
        66% { transform: translate(30px, -40px) scale(1.05) rotate(-240deg); }
      }
      .animate-float-1 {
        animation: float-slow 35s infinite alternate ease-in-out;
      }
      .animate-float-2 {
        animation: float-reverse 40s infinite alternate ease-in-out;
      }

      /* Glassmorphism Card */
      .glass-card {
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255, 255, 255, 0.55);
        box-shadow: 0 30px 60px -15px rgba(0,0,0,0.03), inset 0 1px 0 rgba(255,255,255,0.6);
      }

      .parallax-bg {
        will-change: transform;
      }
    </style>
  </head>
  <body class="bg-creamy-bg text-gray-800 font-outfit overflow-x-hidden selection:bg-triad-purple selection:text-white relative tech-grid">
    <!-- Super subtle background accents & parallax blobs -->
    <div class="fixed top-0 left-0 w-full h-full pointer-events-none z-[-1] overflow-hidden">
        <div id="blob-1" class="parallax-bg absolute -top-48 -left-48 w-[600px] h-[600px] bg-triad-cyan rounded-full mix-blend-multiply opacity-20 filter blur-[120px] animate-float-1"></div>
        <div id="blob-2" class="parallax-bg absolute top-1/3 -right-48 w-[600px] h-[600px] bg-triad-purple rounded-full mix-blend-multiply opacity-15 filter blur-[120px] animate-float-2"></div>
        <div id="blob-3" class="parallax-bg absolute -bottom-48 left-1/4 w-[700px] h-[700px] bg-triad-pink rounded-full mix-blend-multiply opacity-15 filter blur-[150px] animate-float-1"></div>
    </div>

    <Header />

    <!-- MAIN CONTENT -->
    <main class="pt-32">
      <!-- Header Area -->
      <section class="max-w-7xl mx-auto px-6 lg:px-12 py-16 text-center">
        <span class="text-triad-pink font-bold tracking-[0.3em] text-xs uppercase mb-4 block">Get in touch</span>
        <h1 id="contact-title" class="text-4xl md:text-6xl font-black text-gray-900 tracking-tight leading-tight mb-6">
          お問い合わせ
        </h1>
        <p id="contact-desc" class="text-lg text-gray-500 font-light max-w-2xl mx-auto leading-relaxed">
          弊社ホームページをご覧いただき、誠にありがとうございます。人材アウトソーシング事業部、トータルソリューション（法人営業）、およびライバーマネジメント事業に関するお問い合わせやご相談を承っております。お気軽にご相談ください。
        </p>
      </section>

      <section class="max-w-3xl mx-auto px-6 pb-8">
        <div class="bg-white rounded-[32px] p-8 md:p-10 elegant-shadow border border-gray-50 text-gray-500 font-light leading-relaxed space-y-4">
          <p>下記フォームに必要事項をご記入の上、送信してください。</p>
          <p id="contact-notice">3営業日以内に担当者よりご連絡させていただきます。</p>
          <p>お客様の個人情報は、お問い合わせ対応のみに利用し、適切に管理いたします。</p>
        </div>
      </section>

      <!-- Form Section -->
      <section class="max-w-3xl mx-auto px-6 pb-32">
        <div class="glass-card rounded-[40px] p-8 md:p-16 relative overflow-hidden">

          <!-- Decorative ambient background for the card -->
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-triad-purple/10 rounded-full filter blur-3xl pointer-events-none"></div>
          <div class="absolute -bottom-24 -left-24 w-48 h-48 bg-triad-cyan/10 rounded-full filter blur-3xl pointer-events-none"></div>

          <form id="contact-form" action="javascript:void(0);" novalidate class="space-y-10 relative z-10">
            <!-- 題名 (Select) -->
            <div class="flex flex-col">
              <label for="subject" class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-2">題名 <span class="text-triad-red text-[10px] ml-1">※必須</span></label>
              <div class="relative">
                <select id="subject" name="subject" required class="w-full border-b-2 border-gray-200 focus:border-triad-purple outline-none transition-colors py-3 px-1 bg-transparent text-gray-800 font-medium appearance-none cursor-pointer">
                  <option value="" disabled selected>以下から選択してください</option>
                  <optgroup label="人材・トータルソリューション事業部">
                    <option value="corporate_service">サービス導入・協業に関するご相談</option>
                    <option value="corporate_recruit">人材採用・パートナーシップのご相談</option>
                    <option value="corporate_other">その他（コーポレート関連）</option>
                  </optgroup>
                  <optgroup label="ライバーマネジメント事業部">
                    <option value="liver_audition">ライバー所属・オーディション応募</option>
                    <option value="liver_business">企業案件・コラボレーションのご相談</option>
                    <option value="liver_other">その他（ライバーマネジメント関連）</option>
                  </optgroup>
                </select>
                <!-- Custom Arrow -->
                <div class="absolute inset-y-0 right-0 flex items-center pr-2 pointer-events-none text-gray-400">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </div>
              </div>
              <p class="error-msg text-xs text-triad-red mt-2 hidden font-bold">※ 題名を選択してください</p>
            </div>

            <!-- 氏名 (Input) -->
            <div class="flex flex-col">
              <label for="name" class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-2">氏名 <span class="text-triad-red text-[10px] ml-1">※必須</span></label>
              <input id="name" name="name" type="text" required placeholder="おなまえ" class="w-full border-b-2 border-gray-200 focus:border-triad-purple outline-none transition-colors py-3 px-1 bg-transparent text-gray-800 font-medium placeholder-gray-300" />
              <p class="error-msg text-xs text-triad-red mt-2 hidden font-bold">※ 氏名を入力してください</p>
            </div>

            <!-- 電話番号 (Input) -->
            <div class="flex flex-col">
              <label for="tel" class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-2">電話番号 <span class="text-triad-red text-[10px] ml-1">※必須</span></label>
              <input id="tel" name="tel" type="tel" required placeholder="090-0000-0000" class="w-full border-b-2 border-gray-200 focus:border-triad-purple outline-none transition-colors py-3 px-1 bg-transparent text-gray-800 font-medium placeholder-gray-300" />
              <p class="error-msg text-xs text-triad-red mt-2 hidden font-bold">※ 電話番号を入力してください</p>
            </div>

            <!-- メールアドレス (Input) -->
            <div class="flex flex-col">
              <label for="email" class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-2">メールアドレス <span class="text-triad-red text-[10px] ml-1">※必須</span></label>
              <input id="email" name="email" type="email" required placeholder="example@example.com" class="w-full border-b-2 border-gray-200 focus:border-triad-purple outline-none transition-colors py-3 px-1 bg-transparent text-gray-800 font-medium placeholder-gray-300" />
              <p class="error-msg text-xs text-triad-red mt-2 hidden font-bold">※ 有効なメールアドレスを入力してください</p>
            </div>

            <!-- お問合せ内容 (Textarea) -->
            <div class="flex flex-col">
              <label for="message" class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-2">お問合せ内容</label>
              <textarea id="message" name="message" rows="6" placeholder="お問合せ内容をご記入ください" class="w-full border-b-2 border-gray-200 focus:border-triad-purple outline-none transition-colors py-3 px-1 bg-transparent text-gray-800 font-medium placeholder-gray-300 resize-y"></textarea>
            </div>

            <!-- Privacy Policy Notice -->
            <p class="text-xs text-gray-400 leading-relaxed font-light">
              お客様の個人情報は、お問い合わせに対するご返信および対応のみに利用し、適切なセキュリティのもとで厳重に管理いたします。
            </p>

            <!-- Submit Button -->
            <div class="pt-4">
              <button type="submit" class="w-full py-5 rounded-full bg-gray-900 text-white font-bold tracking-widest uppercase shadow-lg hover:bg-gray-800 transition-all hover:scale-[1.02] active:scale-95 duration-300 flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
                送信する
              </button>
              
              <!-- フォームステータス（成功・エラーメッセージ） -->
              <div id="form-status" class="hidden mt-8 p-6 rounded-2xl shadow-lg border text-center transition-all duration-500">
                <div id="form-status-icon" class="mb-3 flex justify-center"></div>
                <h3 id="form-status-title" class="text-lg font-bold mb-2"></h3>
                <p id="form-status-message" class="text-sm font-medium"></p>
              </div>
            </div>

          </form>
        </div>
      </section>
    </main>

    <Footer />

    <!-- Scripts -->
    <script>
      // Smooth Parallax Effect
      const blobs = [
        { el: document.getElementById('blob-1'), speed: 0.12 },
        { el: document.getElementById('blob-2'), speed: -0.08 },
        { el: document.getElementById('blob-3'), speed: 0.05 }
      ];

      let ticking = false;

      function updateParallax() {
        const scrolled = window.scrollY;

        blobs.forEach(blob => {
          if (blob.el) {
            blob.el.style.transform = `translate3d(0, ${scrolled * blob.speed}px, 0)`;
          }
        });

        ticking = false;
      }

      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(updateParallax);
          ticking = true;
        }
      });
      updateParallax();

      // URL Parameter Check & Form Control
      const urlParams = new URLSearchParams(window.location.search);
      const type = urlParams.get('type');
      const subjectSelect = document.getElementById('subject') as HTMLSelectElement;
      const contactTitle = document.getElementById('contact-title');
      const contactDesc = document.getElementById('contact-desc');

      if (type === 'corporate' && subjectSelect) {
        subjectSelect.value = 'corporate_service';
        if (contactTitle) contactTitle.textContent = '人材アウトソーシング・トータルソリューション お問い合わせ';
        if (contactDesc) contactDesc.innerHTML = '人材アウトソーシング事業部、およびトータルソリューション（法人営業）に関するお問い合わせ窓口です。必要事項をご記入の上、送信してください。';
      } else if (type === 'liver' && subjectSelect) {
        subjectSelect.value = 'liver_audition';
        if (contactTitle) contactTitle.textContent = 'ライバーマネジメント お問い合わせ';
        if (contactDesc) contactDesc.innerHTML = 'ライバーマネジメント事業（J.O.L）に関するお問い合わせ・所属応募窓口です。必要事項をご記入の上、送信してください。';
      }

      // Form Submission Logic
      const contactForm = document.getElementById('contact-form') as HTMLFormElement;
      const formStatus = document.getElementById('form-status');
      const formStatusIcon = document.getElementById('form-status-icon');
      const formStatusTitle = document.getElementById('form-status-title');
      const formStatusMessage = document.getElementById('form-status-message');
      
      if (contactForm) {
        const submitBtn = contactForm.querySelector('button[type="submit"]') as HTMLButtonElement;
        const inputs = contactForm.querySelectorAll('input, select, textarea');

        // リアルタイムバリデーション
        inputs.forEach(input => {
          input.addEventListener('input', () => {
            const el = input as HTMLInputElement;
            const errorMsg = el.parentElement?.querySelector('.error-msg');
            if (errorMsg) {
              if (el.validity.valid) {
                errorMsg.classList.add('hidden');
                el.classList.remove('border-triad-red');
                el.classList.add('border-gray-200');
              } else {
                errorMsg.classList.remove('hidden');
                el.classList.remove('border-gray-200');
                el.classList.add('border-triad-red');
              }
            }
          });
        });
        
        contactForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          
          // 送信時バリデーションチェック
          let isValid = true;
          inputs.forEach(input => {
            const el = input as HTMLInputElement;
            if (!el.validity.valid) {
              isValid = false;
              const errorMsg = el.parentElement?.querySelector('.error-msg');
              if (errorMsg) errorMsg.classList.remove('hidden');
              el.classList.remove('border-gray-200');
              el.classList.add('border-triad-red');
            }
          });

          if (!isValid) {
            // 最初のエラー要素にスクロール
            const firstError = contactForm.querySelector('.border-triad-red');
            if (firstError) {
              firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
            return;
          }
          
          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> 送信中...';
          }
          if (formStatus) {
            formStatus.classList.add('hidden');
          }

          const formData = new FormData(contactForm);

          try {
            const response = await fetch('/api/contact', {
              method: 'POST',
              body: formData,
            });

            const result = await response.json();

            if (response.ok) {
              if (formStatus && formStatusIcon && formStatusTitle && formStatusMessage) {
                formStatus.className = 'mt-8 p-6 rounded-2xl shadow-lg border text-center transition-all duration-500 bg-teal-50 border-teal-200 text-teal-900';
                formStatusIcon.innerHTML = '<svg class="w-12 h-12 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>';
                formStatusTitle.textContent = '送信完了';
                formStatusMessage.textContent = 'お問い合わせを受け付けました。担当者からのご連絡をお待ちください。';
              }
              contactForm.reset();
            } else {
              throw new Error(result.error || '送信に失敗しました。');
            }
          } catch (error: any) {
            if (formStatus && formStatusIcon && formStatusTitle && formStatusMessage) {
              formStatus.className = 'mt-8 p-6 rounded-2xl shadow-lg border text-center transition-all duration-500 bg-red-50 border-red-200 text-red-900';
              formStatusIcon.innerHTML = '<svg class="w-12 h-12 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>';
              formStatusTitle.textContent = '送信エラー';
              formStatusMessage.textContent = 'エラー: ' + error.message;
            }
          } finally {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.innerHTML = '送信する';
            }
          }
        });
      }
    </script>
  </body>
</html>
