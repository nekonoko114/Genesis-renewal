---
import { getContactTemplateHtml } from '../emails/ContactTemplate';

const dummyData = {
  name: '山田 太郎',
  tel: '090-1234-5678',
  email: 'yamada@example.com',
  message: 'テストのお問い合わせ内容です。\n改行もこのように表示されます。\nよろしくお願いいたします。'
};

// 法人向け（corporate_service）のHTMLプレビュー
const corporateHtml = getContactTemplateHtml('corporate_service', dummyData);

// ライバー向け（liver_audition）のHTMLプレビュー
const liverHtml = getContactTemplateHtml('liver_audition', dummyData);
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>メールデザインプレビュー</title>
  </head>
  <body style="margin: 0; padding: 0; background: #e5e7eb;">
    <div style="padding: 20px; background: #1f2937; color: white; text-align: center; font-family: sans-serif;">
      <h2>🏢 法人向けデザインプレビュー</h2>
    </div>
    <!-- CSSの干渉を防ぐためiframeで表示 -->
    <iframe srcdoc={corporateHtml} style="width: 100%; height: 800px; border: none; display: block;"></iframe>

    <div style="padding: 20px; background: #1f2937; color: white; text-align: center; font-family: sans-serif; border-top: 4px solid #374151;">
      <h2>🎤 ライバー向けデザインプレビュー</h2>
    </div>
    <!-- CSSの干渉を防ぐためiframeで表示 -->
    <iframe srcdoc={liverHtml} style="width: 100%; height: 800px; border: none; display: block;"></iframe>
  </body>
</html>
