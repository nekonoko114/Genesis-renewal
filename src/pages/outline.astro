---
import '../styles/tailwind.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';

const basePath = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="ja" class="scroll-smooth">
  <head>
    <link rel="icon" type="image/png" href={`${basePath}favicon.png`} />
    <SEO 
      title="会社概要・企業理念 | Genesis合同会社"
      description="Genesis合同会社の会社概要、企業理念、代表者メッセージ。私たちは「個のエンパワーメント」と「企業の変革」を繋ぐプラットフォームとして、新たな価値を創造し続けます。"
    />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700;900&display=swap" rel="stylesheet">

    <style>
      .text-gradient-c {
        background: linear-gradient(to right, #FF9494, #C994FF, #94FFFF);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .elegant-shadow {
        box-shadow: 0 20px 40px -10px rgba(0,0,0,0.05);
      }
      ::-webkit-scrollbar { width: 4px; }
      ::-webkit-scrollbar-track { background: #fcfcfc; }
      ::-webkit-scrollbar-thumb { background: #e5e7eb; border-radius: 2px; }
      ::-webkit-scrollbar-thumb:hover { background: #C994FF; }

      /* Tech Grid Pattern */
      .tech-grid {
        background-image:
          linear-gradient(to right, rgba(0, 0, 0, 0.02) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(0, 0, 0, 0.02) 1px, transparent 1px);
        background-size: 60px 60px;
      }

      /* Floating Blob Animation */
      @keyframes float-slow {
        0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
        33% { transform: translate(50px, -80px) scale(1.15) rotate(120deg); }
        66% { transform: translate(-30px, 30px) scale(0.85) rotate(240deg); }
      }
      @keyframes float-reverse {
        0%, 100% { transform: translate(0, 0) scale(1.1) rotate(0deg); }
        33% { transform: translate(-40px, 60px) scale(0.9) rotate(-120deg); }
        66% { transform: translate(30px, -40px) scale(1.05) rotate(-240deg); }
      }
      .animate-float-1 {
        animation: float-slow 35s infinite alternate ease-in-out;
      }
      .animate-float-2 {
        animation: float-reverse 40s infinite alternate ease-in-out;
      }

      /* Glassmorphism Card */
      .glass-card {
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255, 255, 255, 0.55);
        box-shadow: 0 30px 60px -15px rgba(0,0,0,0.03), inset 0 1px 0 rgba(255,255,255,0.6);
      }

      .parallax-bg {
        will-change: transform;
      }
    </style>
  </head>
  <body class="bg-creamy-bg text-gray-800 font-outfit overflow-x-hidden selection:bg-triad-purple selection:text-white relative tech-grid">
    <!-- Super subtle background accents & parallax blobs -->
    <div class="fixed top-0 left-0 w-full h-full pointer-events-none z-[-1] overflow-hidden">
        <div id="blob-1" class="parallax-bg absolute -top-48 -left-48 w-[600px] h-[600px] bg-triad-cyan rounded-full mix-blend-multiply opacity-20 filter blur-[120px] animate-float-1"></div>
        <div id="blob-2" class="parallax-bg absolute top-1/3 -right-48 w-[600px] h-[600px] bg-triad-purple rounded-full mix-blend-multiply opacity-15 filter blur-[120px] animate-float-2"></div>
        <div id="blob-3" class="parallax-bg absolute -bottom-48 left-1/4 w-[700px] h-[700px] bg-triad-pink rounded-full mix-blend-multiply opacity-15 filter blur-[150px] animate-float-1"></div>
    </div>

    <Header />

    <!-- MAIN CONTENT -->
    <main class="pt-32">
      <!-- Title Section -->
      <section class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-12 py-8 sm:py-16 text-center">
        <span class="text-triad-red font-bold tracking-[0.3em] text-xs uppercase mb-4 block">Who We Are</span>
        <h1 class="text-5xl md:text-7xl font-black text-gray-900 tracking-tight leading-none mb-6">Company Outline</h1>
        <p class="text-lg text-gray-500 font-light max-w-xl mx-auto leading-relaxed">
          可能性を解き放ち、次代の架け橋となる。
        </p>
      </section>

      <!-- Mission & Message Section -->
      <section class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-12 py-4 sm:py-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 sm:gap-12">
          <!-- Philosophy Card -->
          <div class="glass-card rounded-[20px] sm:rounded-[40px] p-4 sm:p-10 md:p-16 flex flex-col justify-between">
            <div>
              <span class="text-triad-red font-bold tracking-[0.2em] text-xs uppercase mb-6 block border-b-2 border-triad-red pb-2 inline-block">Philosophy</span>
              <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-8 leading-tight">人生謳歌</h2>
              <p class="text-gray-900 font-medium text-lg leading-relaxed mb-6">
                「関わるすべての人々が、『生まれてきてよかった』と心から実感できるようなプラットフォームを創造する」
              </p>
              <p class="text-gray-500 font-light leading-relaxed mb-8">
                私たちは、働くスタッフ一人ひとりの個性と想いを第一に尊重します。それぞれのライフスタイルに合わせた柔軟なキャリアステップを提供し、全員が誇りを持って自己実現できる会社であることを目指しています。
              </p>
            </div>
            <div class="w-16 h-1 bg-gradient-to-r from-triad-red to-triad-pink"></div>
          </div>

          <!-- Representative Message -->
          <div class="glass-card rounded-[20px] sm:rounded-[40px] p-4 sm:p-10 md:p-16 flex flex-col justify-between">
            <div>
              <span class="text-triad-purple font-bold tracking-[0.2em] text-xs uppercase mb-6 block border-b-2 border-triad-purple pb-2 inline-block">Message</span>
              <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-8 leading-tight">代表メッセージ</h2>
              <p class="text-gray-500 font-light leading-relaxed mb-6">
                通信分野にとどまらず、多様な事業領域において、「スタッフの声」や「アイデア」を尊重し、個々のライフスタイルやキャリアの希望に応じて新たな価値を創出し続ける組織を目指します。
              </p>
              <p class="text-gray-500 font-light leading-relaxed mb-8">
                やりたい・叶えたいを形にし、多様な働き方と自己実現を支援する企業へ。関わる全ての人が「生まれてよかった」と心から実感できるような場を提供し続けます。
              </p>
            </div>
            <div class="flex items-center gap-4 border-t border-gray-100 pt-6">
              <div>
                <p class="text-xs text-gray-400 font-bold uppercase tracking-widest">Representative Director</p>
                <p class="text-xl font-black text-gray-900">片桐 慶之</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- MVV Section -->
      <section class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-12 py-8 sm:py-24">
        <div class="relative overflow-hidden border-y border-gray-200 py-6 sm:py-14 md:py-20">
          <div class="absolute top-0 left-0 w-28 h-px bg-triad-red"></div>
          <div class="absolute bottom-0 right-0 w-28 h-px bg-triad-cyan"></div>

          <div class="grid grid-cols-1 lg:grid-cols-[0.9fr_1.4fr] gap-16 lg:gap-24">
            <div class="relative">
              <p class="text-[10px] md:text-xs font-bold uppercase tracking-[0.45em] text-gray-400 mb-8">Mission / Vision / Value</p>
              
              <!-- Giant Backdrop Outline Text for Design Impact -->
              <div class="absolute -top-8 -left-3 sm:-left-6 select-none pointer-events-none text-[64px] sm:text-[100px] md:text-[130px] lg:text-[150px] font-black uppercase tracking-widest font-outfit z-0" style="-webkit-text-stroke: 1.5px rgba(0, 0, 0, 0.06); color: transparent;">
                Philosophy
              </div>

              <h2 class="relative z-10 flex flex-row lg:flex-col text-[56px] sm:text-[90px] md:text-[120px] lg:text-[160px] font-black tracking-tight leading-none lg:leading-[0.78] text-gray-900">
                <span>M</span>
                <span>V</span>
                <span>V</span>
              </h2>
              <p class="mt-8 max-w-xs text-base md:text-lg text-gray-600 font-normal leading-relaxed relative z-10">
                Genesisが大切にしている、関わる人たちへの約束と、これから目指す姿。
              </p>
            </div>

            <div class="border-t border-gray-900">
              <article class="grid grid-cols-1 md:grid-cols-[120px_1fr] gap-3 md:gap-12 border-b border-gray-200 py-4 sm:py-10 md:py-12 group">
                <div>
                  <p class="text-5xl md:text-7xl font-black text-gray-900 leading-none">01</p>
                  <p class="mt-3 text-[10px] font-black uppercase tracking-[0.3em] text-gray-900 relative pb-2 inline-block after:absolute after:bottom-0 after:left-0 after:w-6 group-hover:after:w-16 after:h-[3px] after:bg-gradient-to-r after:from-triad-red after:to-triad-pink after:transition-all after:duration-500 after:ease-out">Mission</p>
                </div>
                <div>
                  <h3 class="text-3xl md:text-5xl font-black text-gray-900 leading-[1.15] tracking-tight">
                    関わる一人ひとりが、<br>人生を謳歌できる<br class="hidden md:block">プラットフォームを目指す。
                  </h3>
                  <p class="mt-8 text-base md:text-lg text-gray-600 font-normal leading-relaxed max-w-2xl">
                    Genesis合同会社は、スタッフやパートナー、クライアントなど、関わる全ての人が「生まれてよかった」と心から実感できるような場を提供し続けます。
                  </p>
                </div>
              </article>

              <article class="grid grid-cols-1 md:grid-cols-[120px_1fr] gap-3 md:gap-12 border-b border-gray-200 py-4 sm:py-10 md:py-12 group">
                <div>
                  <p class="text-6xl md:text-7xl font-black text-gray-900 leading-none">02</p>
                  <p class="mt-3 text-[10px] font-black uppercase tracking-[0.3em] text-gray-900 relative pb-2 inline-block after:absolute after:bottom-0 after:left-0 after:w-6 group-hover:after:w-16 after:h-[3px] after:bg-gradient-to-r after:from-triad-purple after:to-triad-cyan after:transition-all after:duration-500 after:ease-out">Vision</p>
                </div>
                <div>
                  <h3 class="text-3xl md:text-5xl font-black text-gray-900 leading-[1.15] tracking-tight">
                    やりたい・叶えたいを形にし、<br>多様な働き方と自己実現を支援する。
                  </h3>
                  <p class="mt-8 text-base md:text-lg text-gray-600 font-normal leading-relaxed max-w-2xl">
                    通信分野にとどまらず、多様な事業領域において、「スタッフの声」や「アイデア」を尊重し、個々のライフスタイルやキャリアの希望に応じて新たな価値を創出し続ける組織を目指します。
                  </p>
                </div>
              </article>

              <article class="grid grid-cols-1 md:grid-cols-[120px_1fr] gap-3 md:gap-12 py-4 sm:py-10 md:py-12 group">
                <div>
                  <p class="text-6xl md:text-7xl font-black text-gray-900 leading-none">03</p>
                  <p class="mt-3 text-[10px] font-black uppercase tracking-[0.3em] text-gray-900 relative pb-2 inline-block after:absolute after:bottom-0 after:left-0 after:w-6 group-hover:after:w-16 after:h-[3px] after:bg-gradient-to-r after:from-triad-lime after:to-triad-cyan after:transition-all after:duration-500 after:ease-out">Value</p>
                </div>
                <div>
                  <h3 class="text-3xl md:text-5xl font-black text-gray-900 leading-[1.15] tracking-tight">
                    人の想いを尊重し、<br>挑戦を支え、共に成長する。
                  </h3>
                  <p class="mt-8 text-base md:text-lg text-gray-600 font-normal leading-relaxed max-w-2xl">
                    一人ひとりの働き方やアイデアを大切にし、挑戦が生まれる環境を整えます。スタッフ、パートナー、クライアントと誠実に向き合い、持続的な成長を実現します。
                  </p>
                </div>
              </article>
            </div>
          </div>
        </div>
      </section>

      <!-- Profile Table Section -->
      <section class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-12 py-6 sm:py-20">
        <div class="glass-card rounded-[20px] sm:rounded-[40px] p-4 sm:p-10 md:p-16 max-w-5xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-12 text-center">Corporate Profile</h2>

          <div class="divide-y divide-gray-100">
            <!-- Row 1 -->
            <div class="py-3.5 sm:py-6 md:py-8 grid grid-cols-1 md:grid-cols-4 gap-1.5 md:gap-8">
              <span class="text-sm md:text-base font-bold uppercase tracking-wider text-triad-purple md:pt-1">Company Name</span>
              <div class="md:col-span-3">
                <p class="text-xl font-bold text-gray-900">Genesis合同会社</p>
              </div>
            </div>

            <!-- Row 2 -->
            <div class="py-3.5 sm:py-6 md:py-8 grid grid-cols-1 md:grid-cols-4 gap-1.5 md:gap-8">
              <span class="text-sm md:text-base font-bold uppercase tracking-wider text-triad-purple md:pt-1">Location</span>
              <div class="md:col-span-3">
                <p class="text-xl text-gray-900 font-medium leading-relaxed">〒550-0002 大阪府大阪市西区江戸堀1-19-10 三共肥後橋ビル2F</p>
              </div>
            </div>

            <!-- Row 3 -->
            <div class="py-3.5 sm:py-6 md:py-8 grid grid-cols-1 md:grid-cols-4 gap-1.5 md:gap-8">
              <span class="text-sm md:text-base font-bold uppercase tracking-wider text-triad-purple md:pt-1">Business Areas</span>
              <div class="md:col-span-3 text-lg text-gray-800 font-normal space-y-3">
                <div class="flex items-center gap-2.5">
                  <span class="w-1.5 h-1.5 bg-triad-purple flex-shrink-0 rotate-45"></span>
                  <span>人材アウトソーシング事業部</span>
                </div>
                <div class="flex items-center gap-2.5">
                  <span class="w-1.5 h-1.5 bg-triad-purple flex-shrink-0 rotate-45"></span>
                  <span>トータルソリューション事業部</span>
                </div>
                <div class="flex items-center gap-2.5">
                  <span class="w-1.5 h-1.5 bg-triad-purple flex-shrink-0 rotate-45"></span>
                  <span>ライバーマネジメント事業部</span>
                </div>
              </div>
            </div>

            <!-- Row 4 -->
            <div class="py-3.5 sm:py-6 md:py-8 grid grid-cols-1 md:grid-cols-4 gap-1.5 md:gap-8">
              <span class="text-sm md:text-base font-bold uppercase tracking-wider text-triad-purple md:pt-1">Contact</span>
              <div class="md:col-span-3 text-lg text-gray-800 font-normal space-y-2">
                <p>電話番号 : <a href="tel:06-6147-3440" class="hover:text-triad-purple transition-all font-medium">06-6147-3440</a></p>
                <p>FAX番号 : 06-6147-8960</p>
                <p>メール : <a href="mailto:info@genesis-llc.co.jp" class="hover:text-triad-purple transition-all font-medium">info@genesis-llc.co.jp</a></p>
              </div>
            </div>

            <!-- Row 5 -->
            <div class="py-3.5 sm:py-6 md:py-8 grid grid-cols-1 md:grid-cols-4 gap-1.5 md:gap-8">
              <span class="text-sm md:text-base font-bold uppercase tracking-wider text-triad-purple md:pt-1">Directors</span>
              <div class="md:col-span-3 text-lg md:text-xl text-gray-900 font-medium space-y-1">
                <p>代表社員：片桐 慶之</p>
                <p>取締役：前原 京典</p>
              </div>
            </div>

            <!-- Row 6 -->
            <div class="py-3.5 sm:py-6 md:py-8 grid grid-cols-1 md:grid-cols-4 gap-1.5 md:gap-8">
              <span class="text-sm md:text-base font-bold uppercase tracking-wider text-triad-purple md:pt-1">Established</span>
              <div class="md:col-span-3 text-lg md:text-xl text-gray-900 font-medium">
                <p>2023年7月27日</p>
              </div>
            </div>

            <!-- Row 7 -->
            <div class="py-3.5 sm:py-6 md:py-8 grid grid-cols-1 md:grid-cols-4 gap-1.5 md:gap-8">
              <span class="text-sm md:text-base font-bold uppercase tracking-wider text-triad-purple md:pt-1">Capital</span>
              <div class="md:col-span-3 text-lg md:text-xl text-gray-900 font-medium">
                <p>501万円</p>
              </div>
            </div>

            <!-- Row 8 -->
            <div class="py-3.5 sm:py-6 md:py-8 grid grid-cols-1 md:grid-cols-4 gap-1.5 md:gap-8">
              <span class="text-sm md:text-base font-bold uppercase tracking-wider text-triad-purple md:pt-1">Employees</span>
              <div class="md:col-span-3 text-lg md:text-xl text-gray-900 font-medium">
                <p>152名 <span class="text-sm text-gray-400 font-normal">（社員・個人事業主・アルバイト含む ※2026年4月時点）</span></p>
              </div>
            </div>

            <!-- Row 9 -->
            <div class="py-3.5 sm:py-6 md:py-8 grid grid-cols-1 md:grid-cols-4 gap-1.5 md:gap-8">
              <span class="text-sm md:text-base font-bold uppercase tracking-wider text-triad-purple md:pt-1">Partners</span>
              <div class="md:col-span-3 text-lg text-gray-800 font-normal grid grid-cols-1 md:grid-cols-2 gap-y-3 gap-x-6">
                <div class="flex items-center gap-2.5">
                  <span class="w-1.5 h-1.5 bg-triad-purple flex-shrink-0 rotate-45"></span>
                  <span>株式会社First Project</span>
                </div>
                <div class="flex items-center gap-2.5">
                  <span class="w-1.5 h-1.5 bg-triad-purple flex-shrink-0 rotate-45"></span>
                  <span>株式会社TDモバイル</span>
                </div>
                <div class="flex items-center gap-2.5">
                  <span class="w-1.5 h-1.5 bg-triad-purple flex-shrink-0 rotate-45"></span>
                  <span>株式会社Nex-T</span>
                </div>
                <div class="flex items-center gap-2.5">
                  <span class="w-1.5 h-1.5 bg-triad-purple flex-shrink-0 rotate-45"></span>
                  <span>株式会社クレイス</span>
                </div>
                <div class="flex items-center gap-2.5">
                  <span class="w-1.5 h-1.5 bg-triad-purple flex-shrink-0 rotate-45"></span>
                  <span>株式会社新通エスピー</span>
                </div>
                <div class="flex items-center gap-2.5">
                  <span class="w-1.5 h-1.5 bg-triad-purple flex-shrink-0 rotate-45"></span>
                  <span>株式会社TIR</span>
                </div>
                <div class="flex items-center gap-2.5">
                  <span class="w-1.5 h-1.5 bg-triad-purple flex-shrink-0 rotate-45"></span>
                  <span>株式会社ファントゥ</span>
                </div>
                <div class="flex items-center gap-2.5">
                  <span class="w-1.5 h-1.5 bg-triad-purple flex-shrink-0 rotate-45"></span>
                  <span>株式会社サンダータービュランス</span>
                </div>
                <div class="flex items-center gap-2.5">
                  <span class="w-1.5 h-1.5 bg-triad-purple flex-shrink-0 rotate-45"></span>
                  <span>株式会社SUXPERIA</span>
                </div>
              </div>
            </div>

          </div>
        </div>
      </section>
    </main>

    <Footer />

    <!-- Scripts -->
    <script is:inline>
      // Smooth Parallax Effect
      const blobs = [
        { el: document.getElementById('blob-1'), speed: 0.12 },
        { el: document.getElementById('blob-2'), speed: -0.08 },
        { el: document.getElementById('blob-3'), speed: 0.05 }
      ];

      let ticking = false;

      function updateParallax() {
        const scrolled = window.pageYOffset;

        blobs.forEach(blob => {
          if (blob.el) {
            blob.el.style.transform = `translate3d(0, ${scrolled * blob.speed}px, 0)`;
          }
        });

        ticking = false;
      }

      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(updateParallax);
          ticking = true;
        }
      });
      updateParallax();
    </script>
  </body>
</html>
