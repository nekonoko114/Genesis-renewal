---
import "../styles/tailwind.css";
import { sanitize } from "../utils/sanitize";
import { formatPostDate, getPosts } from "../lib/wordpress";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const posts = await getPosts({ perPage: 3 });
const basePath = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja" class="scroll-smooth">
  <head>
    <!-- Wistia Player Common and Video Scripts -->
    <script src="https://fast.wistia.com/player.js" async></script>
    <script
      src="https://fast.wistia.com/embed/038mz4dv5n.js"
      async
      type="module"></script>
    <script
      src="https://fast.wistia.com/embed/0uofnbd1zu.js"
      async
      type="module"></script>

    <link rel="icon" type="image/png" href={`${basePath}favicon.png`} />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Genesis - sing of joys of the life</title>
    <meta
      name="description"
      content="Genesis合同会社では大阪を中心に東北、九州でイベント事業、通信販売事業などを行っております。多くのパートナー様に恵まれいいスタートを発信できました。"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700;900&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <style is:inline>
      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        font-style: italic;
      }
      .text-gradient-c {
        background: linear-gradient(to right, #ff9494, #c994ff, #94ffff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .elegant-shadow {
        box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.05);
      }
      ::-webkit-scrollbar {
        width: 4px;
      }
      ::-webkit-scrollbar-track {
        background: #fcfcfc;
      }
      ::-webkit-scrollbar-thumb {
        background: #e5e7eb;
        border-radius: 2px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #c994ff;
      }

      /* Tech Grid Pattern */
      .tech-grid {
        background-image:
          linear-gradient(to right, rgba(0, 0, 0, 0.02) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(0, 0, 0, 0.02) 1px, transparent 1px);
        background-size: 60px 60px;
      }

      /* Floating Blob Animation */
      @keyframes float-slow {
        0%,
        100% {
          transform: translate(0, 0) scale(1) rotate(0deg);
        }
        33% {
          transform: translate(50px, -80px) scale(1.15) rotate(120deg);
        }
        66% {
          transform: translate(-30px, 30px) scale(0.85) rotate(240deg);
        }
      }
      @keyframes float-reverse {
        0%,
        100% {
          transform: translate(0, 0) scale(1.1) rotate(0deg);
        }
        33% {
          transform: translate(-40px, 60px) scale(0.9) rotate(-120deg);
        }
        66% {
          transform: translate(30px, -40px) scale(1.05) rotate(-240deg);
        }
      }
      .animate-float-1 {
        animation: float-slow 35s infinite alternate ease-in-out;
      }
      .animate-float-2 {
        animation: float-reverse 40s infinite alternate ease-in-out;
      }

      /* Glassmorphism Card */
      .glass-card {
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255, 255, 255, 0.55);
        box-shadow:
          0 30px 60px -15px rgba(0, 0, 0, 0.03),
          inset 0 1px 0 rgba(255, 255, 255, 0.6);
      }

      /* Premium Icon Container */
      .premium-icon-container {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 4.5rem;
        height: 4.5rem;
        border-radius: 1.25rem;
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.05);
        transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        z-index: 10;
        cursor: pointer;
      }
      .premium-icon-glow {
        position: absolute;
        inset: -4px;
        border-radius: 1.35rem;
        filter: blur(14px);
        opacity: 0;
        transition: opacity 0.6s ease;
        z-index: -1;
      }
      .pulse-ring-outer {
        position: absolute;
        inset: -1px;
        border-radius: 1.25rem;
        border: 1px solid currentColor;
        opacity: 0;
        transform: scale(1);
        pointer-events: none;
        transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .premium-icon-container:hover {
        transform: translateY(-6px) scale(1.05);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
        background: #fff;
      }
      .premium-icon-container:hover .premium-icon-glow {
        opacity: 0.4;
      }
      .premium-icon-container:hover .pulse-ring-outer {
        opacity: 0.6;
        transform: scale(1.4);
      }

      /* Gradient Text Icons */
      .icon-gradient-lime {
        background: linear-gradient(135deg, #c9ff94, #00c9a7);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .icon-gradient-purple {
        background: linear-gradient(135deg, #c994ff, #845ec2);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .icon-gradient-cyan {
        background: linear-gradient(135deg, #94ffff, #0089ba);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      /* Parallax Adjustments */
      .parallax-bg {
        will-change: transform;
      }
      .parallax-img-container {
        position: relative;
        overflow: hidden;
      }
      .parallax-img {
        will-change: transform;
        transform: scale(1.15);
      }

      /* Scroll Reveal Text (Wipe effect) */
      .reveal-text {
        --progress: 100%; /* Progressive enhancement: 100% by default */
        display: inline;
        background-repeat: no-repeat;
        transition:
          -webkit-mask-image 0.1s linear,
          mask-image 0.1s linear;
        -webkit-mask-image: linear-gradient(
          to right,
          rgba(0, 0, 0, 1) var(--progress),
          rgba(0, 0, 0, 0.15) var(--progress)
        );
        mask-image: linear-gradient(
          to right,
          rgba(0, 0, 0, 1) var(--progress),
          rgba(0, 0, 0, 0.15) var(--progress)
        );
      }

      /* Floating SVGs & Animations */
      @keyframes float-gentle {
        0%,
        100% {
          transform: translateY(0) rotate(0deg);
        }
        50% {
          transform: translateY(-15px) rotate(5deg);
        }
      }
      @keyframes spin-slow {
        from {
          transform: rotate(0deg);
        }
        to {
          transform: rotate(360deg);
        }
      }
      @keyframes pulse-slow {
        0%,
        100% {
          opacity: 0.2;
          transform: scale(1);
        }
        50% {
          opacity: 0.5;
          transform: scale(1.1);
        }
      }
      .animate-float-gentle {
        animation: float-gentle 8s infinite ease-in-out;
      }
      .animate-spin-slow {
        animation: spin-slow 25s infinite linear;
      }
      .animate-spin-reverse {
        animation: spin-slow 30s infinite linear reverse;
      }
      .animate-pulse-slow {
        animation: pulse-slow 4s infinite ease-in-out;
      }

      @keyframes marquee {
        from {
          transform: translateX(0);
        }
        to {
          transform: translateX(-50%);
        }
      }
      @keyframes image-drift {
        0%,
        100% {
          transform: translate3d(0, 0, 0) rotate(var(--tilt, 0deg));
        }
        50% {
          transform: translate3d(0, -18px, 0)
            rotate(calc(var(--tilt, 0deg) * -1));
        }
      }
      @keyframes line-scan {
        0% {
          transform: translateY(-100%);
          opacity: 0;
        }
        20%,
        80% {
          opacity: 0.55;
        }
        100% {
          transform: translateY(100%);
          opacity: 0;
        }
      }
      .hero-collage {
        position: absolute;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
      }
      .hero-collage::before {
        content: "";
        position: absolute;
        inset: 9rem 2rem 4rem;
        border: 1px solid rgba(17, 24, 39, 0.08);
        border-radius: 999px;
        background:
          radial-gradient(
            circle at 20% 30%,
            rgba(148, 255, 255, 0.35),
            transparent 26%
          ),
          radial-gradient(
            circle at 80% 30%,
            rgba(201, 148, 255, 0.26),
            transparent 24%
          ),
          radial-gradient(
            circle at 55% 82%,
            rgba(255, 148, 148, 0.24),
            transparent 28%
          );
        filter: blur(0.2px);
      }
      .hero-collage::after {
        content: "";
        position: absolute;
        top: 12%;
        bottom: 8%;
        left: 50%;
        width: 1px;
        background: linear-gradient(
          to bottom,
          transparent,
          rgba(255, 20, 20, 0.32),
          transparent
        );
        animation: line-scan 6s infinite ease-in-out;
      }
      .collage-card {
        position: absolute;
        overflow: hidden;
        border-radius: 2rem;
        background: rgba(255, 255, 255, 0.85);
        border: 1px solid rgba(255, 255, 255, 0.75);
        box-shadow: 0 30px 80px -28px rgba(15, 23, 42, 0.32);
        animation: image-drift 9s infinite ease-in-out;
      }
      .collage-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .collage-card::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          135deg,
          rgba(255, 255, 255, 0.14),
          transparent 42%,
          rgba(15, 23, 42, 0.18)
        );
      }
      .collage-card-1 {
        --tilt: -7deg;
        width: min(26vw, 360px);
        height: min(30vw, 430px);
        left: 3vw;
        top: 18vh;
      }
      .collage-card-2 {
        --tilt: 8deg;
        width: min(23vw, 320px);
        height: min(27vw, 380px);
        right: 4vw;
        top: 16vh;
        animation-delay: -2s;
      }
      .collage-card-3 {
        --tilt: 5deg;
        width: min(20vw, 280px);
        height: min(15vw, 210px);
        left: 14vw;
        bottom: 9vh;
        animation-delay: -4s;
      }
      .collage-card-4 {
        --tilt: -5deg;
        width: min(18vw, 250px);
        height: min(14vw, 190px);
        right: 14vw;
        bottom: 11vh;
        animation-delay: -6s;
      }
      .hero-video-wrap {
        position: absolute;
        inset: 0;
        overflow: hidden;
        background: #080a10;
      }
      .hero-video {
        width: 100%;
        height: 100%;
        object-fit: contain;
        transform: none;
        background: #080a10;
      }
      .hero-video-overlay {
        position: absolute;
        inset: 0;
        background:
          radial-gradient(
            circle at 18% 18%,
            rgba(148, 255, 255, 0.08),
            transparent 30%
          ),
          radial-gradient(
            circle at 82% 16%,
            rgba(201, 148, 255, 0.08),
            transparent 30%
          ),
          linear-gradient(
            180deg,
            rgba(8, 10, 16, 0.08),
            transparent 50%,
            rgba(252, 252, 252, 0.48)
          );
      }
      .hero-video-grain {
        position: absolute;
        inset: 0;
        opacity: 0.06;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
        background-size: 44px 44px;
        mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0.9),
          transparent 85%
        );
      }
      .hero-copy-panel {
        border: 1px solid rgba(255, 255, 255, 0.18);
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(20px);
        box-shadow: 0 40px 90px -45px rgba(0, 0, 0, 0.7);
      }
      .hero-vertical-copy {
        position: relative;
        z-index: 10;
        display: block;
        width: auto;
        min-height: auto;
        margin-top: 0;
        margin-left: auto;
        margin-right: auto;
        text-align: center;
      }
      .hero-vertical-line {
        display: block;
        writing-mode: horizontal-tb;
        letter-spacing: 0;
        line-height: 0.95;
        filter: drop-shadow(0 12px 30px rgba(255, 255, 255, 0.86));
      }
      .hero-vertical-line:nth-child(1) {
        transform: none;
      }
      .hero-vertical-line:nth-child(2) {
        transform: none;
      }
      .hero-vertical-line:nth-child(3) {
        transform: none;
      }
      #header {
        transition:
          transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
          opacity 0.5s,
          background-color 0.5s,
          border-color 0.5s,
          box-shadow 0.5s;
      }
      body[data-header-mode="cinematic"] #header {
        opacity: 0;
        transform: translateY(-100%);
        pointer-events: none;
      }
      body[data-header-mode="cinematic"] #header.is-visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }
      .signal-pill {
        position: absolute;
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.7);
        background: rgba(255, 255, 255, 0.82);
        box-shadow: 0 22px 50px -28px rgba(15, 23, 42, 0.35);
        padding: 0.7rem 1rem;
        font-size: 0.72rem;
        font-weight: 900;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #111827;
        backdrop-filter: blur(18px);
      }
      #movie-first-view .signal-pill {
        background: rgba(255, 255, 255, 0.62);
        opacity: 0.72;
      }
      #movie-first-view .startup-marquee {
        opacity: 0.78;
      }
      .signal-pill span {
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 999px;
        background: #ff1414;
        box-shadow: 0 0 24px rgba(255, 20, 20, 0.6);
      }
      .startup-marquee {
        width: min(100%, 1120px);
        overflow: hidden;
        border-radius: 999px;
        border: 1px solid rgba(17, 24, 39, 0.08);
        background: rgba(255, 255, 255, 0.66);
        backdrop-filter: blur(16px);
        box-shadow: 0 18px 50px -32px rgba(15, 23, 42, 0.4);
      }
      .startup-marquee-track {
        display: flex;
        width: max-content;
        animation: marquee 28s linear infinite;
      }
      .startup-marquee-track span {
        display: inline-flex;
        align-items: center;
        padding: 0.85rem 1.35rem;
        font-size: 0.72rem;
        font-weight: 900;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: #111827;
        white-space: nowrap;
      }
      .startup-marquee-track span::before {
        content: "";
        width: 0.45rem;
        height: 0.45rem;
        margin-right: 1rem;
        border-radius: 999px;
        background: linear-gradient(135deg, #ff9494, #c994ff, #94ffff);
      }
      .impact-card {
        position: relative;
        overflow: hidden;
        border-radius: 2rem;
        background: rgba(255, 255, 255, 0.76);
        border: 1px solid rgba(255, 255, 255, 0.7);
        box-shadow: 0 24px 70px -38px rgba(15, 23, 42, 0.45);
      }
      .impact-card::after {
        content: "";
        position: absolute;
        inset: auto -20% -55% -20%;
        height: 100%;
        background: radial-gradient(
          circle,
          rgba(201, 148, 255, 0.3),
          transparent 64%
        );
      }
      .service-item {
        position: relative;
        z-index: 0;
      }
      .service-item::before {
        content: attr(data-index);
        position: absolute;
        top: -3rem;
        right: -0.25rem; /* デフォルトは右寄せ (01, 03) */
        z-index: 0;
        font-size: clamp(4.5rem, 12vw, 10rem);
        line-height: 1;
        font-weight: 900;
        font-style: italic;
        letter-spacing: -0.08em;
        color: rgba(17, 24, 39, 0.055);
        pointer-events: none;
      }
      /* 2番目のアイテム (02) は左寄せに配置 */
      .service-item:nth-child(even)::before {
        right: auto;
        left: -0.25rem;
      }
      .service-item > * {
        position: relative;
        z-index: 1;
      }
      .service-image-shell {
        isolation: isolate;
        box-shadow:
          24px 24px 0 -8px rgba(201, 148, 255, 0.18),
          -18px -18px 0 -8px rgba(148, 255, 255, 0.2),
          0 34px 80px -42px rgba(15, 23, 42, 0.44);
      }
      .service-image-shell::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: -1;
        border-radius: 3rem;
        background: linear-gradient(
          135deg,
          rgba(255, 148, 148, 0.34),
          rgba(201, 148, 255, 0.18),
          rgba(148, 255, 255, 0.26)
        );
        transform: rotate(-3deg) scale(1.04);
      }
      @media (max-width: 900px) {
        .hero-video-overlay {
          background:
            radial-gradient(
              circle at 50% 18%,
              rgba(201, 148, 255, 0.08),
              transparent 34%
            ),
            linear-gradient(
              180deg,
              rgba(8, 10, 16, 0.06),
              transparent 52%,
              rgba(252, 252, 252, 0.5)
            );
        }
        .collage-card {
          opacity: 0.45;
          filter: saturate(0.9);
        }
        .collage-card-1 {
          width: 42vw;
          height: 50vw;
          left: -15vw;
          top: 19vh;
        }
        .collage-card-2 {
          width: 38vw;
          height: 47vw;
          right: -13vw;
          top: 18vh;
        }
        .collage-card-3,
        .collage-card-4 {
          display: none;
        }
        .hero-collage::before {
          inset: 8rem 0.75rem 4rem;
        }
      }
    </style>
  </head>
  <body
    data-header-mode="cinematic"
    class="bg-creamy-bg text-gray-800 font-outfit overflow-x-hidden selection:bg-triad-purple selection:text-white relative tech-grid"
  >
    <!-- Super subtle background accents & parallax blobs -->
    <div
      class="fixed top-0 left-0 w-full h-full pointer-events-none z-[-1] overflow-hidden"
    >
      <div
        id="blob-1"
        class="parallax-bg absolute -top-48 -left-48 w-[600px] h-[600px] bg-triad-cyan rounded-full mix-blend-multiply opacity-20 filter blur-[120px] animate-float-1"
      >
      </div>
      <div
        id="blob-2"
        class="parallax-bg absolute top-1/3 -right-48 w-[600px] h-[600px] bg-triad-purple rounded-full mix-blend-multiply opacity-15 filter blur-[120px] animate-float-2"
      >
      </div>
      <div
        id="blob-3"
        class="parallax-bg absolute -bottom-48 left-1/4 w-[700px] h-[700px] bg-triad-pink rounded-full mix-blend-multiply opacity-15 filter blur-[150px] animate-float-1"
      >
      </div>
    </div>

    <Header />

    <!-- MAIN CONTENT -->
    <main>
      <!-- First View Movie Section -->
      <section
        id="movie-first-view"
        class="relative w-full min-h-screen flex items-end justify-center px-6 pb-8 md:pb-10 overflow-hidden bg-black"
      >
        <div class="hero-video-wrap">
          <!-- PC用 Wistia Player (768px以上で表示) -->
          <div class="hidden md:block w-full h-full relative overflow-hidden hidden-on-mobile">
            <wistia-player
              media-id="038mz4dv5n"
              autoplay="true"
              muted="true"
              loop="true"
              controlsVisibleOnLoad="false"
              playbar="false"
              playButton="false"
              smallPlayButton="false"
              volumeControl="false"
              fullscreenButton="false"
              settingsControl="false"
              fit-strategy="cover"
              class="w-full h-full"
              style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); min-width: 100%; min-height: 100%; object-fit: cover; display: block;"
            >
            </wistia-player>
          </div>

          <!-- スマホ用 Wistia Player (767px以下で表示) -->
          <div class="block md:hidden w-full h-full relative overflow-hidden hidden-on-desktop">
            <wistia-player
              media-id="0uofnbd1zu"
              autoplay="true"
              muted="true"
              loop="true"
              controlsVisibleOnLoad="false"
              playbar="false"
              playButton="false"
              smallPlayButton="false"
              volumeControl="false"
              fullscreenButton="false"
              settingsControl="false"
              fit-strategy="cover"
              class="w-full h-full"
              style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); min-width: 100%; min-height: 100%; object-fit: cover; display: block;"
            >
            </wistia-player>
          </div>
          <!--  -->
        </div>
      </section>

      <!-- Premium HERO Section -->
      <section
        id="hero"
        class="relative w-full min-h-[80vh] md:min-h-screen flex flex-col items-center justify-center text-center px-4 md:px-6 overflow-hidden"
      >
        <div class="hero-collage">
          <div class="collage-card collage-card-1">
            <img
              src={`${basePath}assets/images/pages/jol_streamer_showcase.webp`}
              alt="ライブ配信とクリエイターのビジュアル"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="collage-card collage-card-2">
            <img
              src={`${basePath}assets/images/pages/telecom_outsourcing.webp`}
              alt="人材ソリューションのビジュアル"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="collage-card collage-card-3">
            <img
              src={`${basePath}assets/images/pages/corporate_sales.webp`}
              alt="法人向けソリューションのビジュアル"
              loading="lazy"
              decoding="async"
            />
          </div>
