    <Footer />

    <script>
      import "../scripts/scroll-animations";
    </script>

    <!-- Scripts -->
    <script is:inline>
      // Cinematic first-view header reveal on scroll (after 1000px)
      const header = document.getElementById("header");
      const headerRevealOffset = 1000;
      let ticking = false;

      const updateHeaderState = () => {
        if (window.scrollY > headerRevealOffset) {
          header.classList.add("is-visible");
          header.classList.add(
            "border-gray-200",
            "shadow-sm",
            "bg-creamy-bg/95",
          );
          header.classList.remove("border-transparent", "bg-creamy-bg/80");
        } else {
          header.classList.remove("is-visible");
          header.classList.remove(
            "border-gray-200",
            "shadow-sm",
            "bg-creamy-bg/95",
          );
          header.classList.add("border-transparent", "bg-creamy-bg/80");
        }
        ticking = false;
      };

      const onScroll = () => {
        if (!ticking) {
          window.requestAnimationFrame(updateHeaderState);
          ticking = true;
        }
      };

      window.addEventListener("scroll", onScroll, { passive: true });
      updateHeaderState();
    </script></body
  >
</html>
